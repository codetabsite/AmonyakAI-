{
  "name": "amonyakai",
  "version": "1.0.0",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux AppImage"
  },
  "build": {
    "appId": "com.amonyak.ai",
    "productName": "AmonyakAI",
    "files": ["src/**/*", "assets/**/*"],
    "extraResources": [
      { "from": "bin/", "to": "bin/", "filter": ["**/*"] }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
